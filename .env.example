# Locus — all-free configuration. Copy to .env.local and fill in. See FREE_STACK.md.

# ── LLM (pick ONE provider; the AI SDK swaps them — see src/lib/ai/provider.ts) ──
LLM_PROVIDER=gemini                 # gemini | ollama
GEMINI_API_KEY=                     # Google AI Studio, free tier (hosted demo)
GEMINI_MODEL=gemini-2.5-flash       # free-tier chat model
# Local alternative (no key): run Ollama, then set LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ── Embeddings (via the AI SDK / Gemini — free tier, multilingual, serverless-safe) ──
# Dimension locked at 768 (vector(768)). Uses GEMINI_API_KEY.
EMBEDDINGS_MODEL=gemini-embedding-001

# ── Database (local docker by default; Supabase/Neon free tier for hosted) ──
# Local docker:  postgres://locus:locus@localhost:5432/locus
# Supabase pooler (transaction mode, port 6543) for the deployed app.
DATABASE_URL=postgres://locus:locus@localhost:5432/locus

# ── Geo tools (Phase 3; Nominatim/Overpass/Open-Meteo/SunCalc need no key) ──
ORS_API_KEY=                        # OpenRouteService free key (routing + isochrones)

# ── Basemap ──
# OpenFreeMap needs no env: style https://tiles.openfreemap.org/styles/liberty (no key, no signup)

# ── Feedback form (landing + top-bar) → email ──
# The /api/feedback route emails suggestions to FEEDBACK_TO. Set ONE provider key to enable delivery;
# with neither set the message is kept in the server logs (nothing is lost) and the form still works.
FEEDBACK_TO=ivettadashkovafsd@gmail.com
# Resend (recommended, free tier): create a key at resend.com. The default RESEND_FROM
# (onboarding@resend.dev) delivers to your own account email with no domain to verify.
RESEND_API_KEY=
FEEDBACK_FROM=Locus Feedback <onboarding@resend.dev>
# SendGrid alternative — needs a verified sender in SENDGRID_FROM.
SENDGRID_API_KEY=
SENDGRID_FROM=no-reply@locus-dun.vercel.app

# ── Tracing (Langfuse free tier; optional — no-op if unset) ──
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASEURL=https://cloud.langfuse.com

# ── Auth (Auth.js / NextAuth — gates the whole app) ──
# Required in production: a random secret for signing the JWT session cookie.
#   generate with:  openssl rand -base64 32
AUTH_SECRET=
# Optional OAuth providers — each "Sign in with …" button appears only when its pair is set.
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ── Payments (Stripe TEST mode; optional) ──
# When BOTH are set, the per-user AI credit paywall turns on: each AI request spends 1 credit, and
# users buy a 5-credit pack via Stripe Checkout (test card 4242 4242 4242 4242). Unset → paywall off.
#   1. Test secret key from https://dashboard.stripe.com/test/apikeys  (starts sk_test_)
#   2. Webhook signing secret (starts whsec_):
#        local:  stripe listen --forward-to localhost:3000/api/stripe/webhook
#        prod:   add an endpoint for /api/stripe/webhook (event: checkout.session.completed)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── SEO (optional) ──
# Google Search Console → "HTML tag" verification: paste just the content token here to emit the
# <meta name="google-site-verification"> tag. Leave empty if unused.
GOOGLE_SITE_VERIFICATION=

# ── Error monitoring (Sentry; optional) ──
# When set, uncaught server + client errors are reported to Sentry (errors only, no perf tracing —
# request/AI tracing goes to Langfuse). Unset → Sentry is a no-op. DSN from your Sentry project.
#   SENTRY_DSN — server; NEXT_PUBLIC_SENTRY_DSN — client (same DSN value, public-safe).
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
